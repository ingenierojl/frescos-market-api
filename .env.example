# Postgres de Supabase. OJO: usar el prefijo postgresql+asyncpg:// (no postgresql://)
# Sacar de Supabase: boton "Connect" -> Connection string -> Session pooler -> URI
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# URL base de tu proyecto (Settings -> API -> Project URL). Se usa para armar la URL del
# JWKS (Settings -> API -> JWT Keys) y verificar los tokens firmados con la clave publica
# ECC/ES256 de Supabase -- no hace falta copiar ningun secreto para esto.
SUPABASE_URL=https://xxxx.supabase.co

# Dominios permitidos para CORS, separados por coma (front de Netlify + localhost para dev)
CORS_ORIGINS=http://localhost:8081,https://tu-sitio.netlify.app

# Email exacto (el que usas para loguearte con Google) que tiene acceso a /api/v1/admin/*
ADMIN_EMAIL=tu-email@gmail.com
